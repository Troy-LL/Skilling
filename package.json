{
  "name": "skilling",
  "version": "1.7.1",
  "description": "Skilling MCP — filesystem skill router (list / select / load / cleanup)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "mcp": "node dist/index.js",
    "postinstall": "node scripts/postinstall.mjs",
    "test": "npm run build && node --test dist/**/*.test.js && npm run test:setup && npm run test:auto-begin-hook && npm run test:session-end-hook && npm run smoke",
    "smoke": "node scripts/mcp-smoke.mjs",
    "test:setup": "node scripts/test-setup.mjs",
    "test:session-end-hook": "node scripts/test-session-end-hook.mjs",
    "test:auto-begin-hook": "node scripts/test-auto-begin-hook.mjs",
    "skills:add": "node scripts/skills-add-local.mjs",
    "benchmark": "npm run build && node scripts/token-benchmark.mjs",
    "pack:check": "npm pack --dry-run",
    "deeplink": "node scripts/generate-mcp-deeplink.mjs"
  },
  "files": [
    "dist/**",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    ".agents/skills/**",
    "!.agents/skills/create-hook",
    "!.agents/skills/skill-creator/scripts",
    "!.agents/skills/skill-creator/eval-viewer",
    "!.agents/skills/skill-creator/agents",
    "!.agents/skills/skill-creator/assets",
    "!.agents/skills/skill-creator/references",
    "!.agents/skills/mcp-builder/scripts",
    "!.agents/skills/mcp-builder/reference",
    ".agents/skills-meta/**",
    "scripts/run-mcp.mjs",
    "scripts/postinstall.mjs",
    "scripts/setup.mjs",
    "scripts/setup-lib.mjs",
    "scripts/hook-paths.mjs",
    "hooks/**",
    "mcp.json",
    ".cursor-plugin/**",
    ".cursor/rules/**",
    ".cursor/hooks.json",
    "assets/**",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "bin": {
    "skilling": "scripts/run-mcp.mjs"
  },
  "keywords": [
    "mcp",
    "cursor",
    "skills",
    "agent",
    "routing",
    "token-budget",
    "model-context-protocol"
  ],
  "author": "Skilling Contributors",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Troy-LL/SkillPilot.git"
  },
  "homepage": "https://github.com/Troy-LL/SkillPilot#readme",
  "bugs": {
    "url": "https://github.com/Troy-LL/SkillPilot/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3"
  }
}
